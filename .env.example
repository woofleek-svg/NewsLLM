# ============================================================
# AI News Aggregator — Environment Variables
# Copy to .env and fill in values before running docker compose
# ============================================================

# --- Miniflux Postgres ---
MINIFLUX_DB_PASSWORD=changeme_miniflux_db

# --- Miniflux ---
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=changeme_admin

# --- Output Postgres ---
OUTPUT_DB_PASSWORD=changeme_output_db

# --- News Processor ---
# Generate this from Miniflux UI -> Settings -> API Keys after first boot
MINIFLUX_API_KEY=

# llama.cpp server endpoint (adjust to your homelab IP/hostname)
LLAMA_CPP_URL=http://host.docker.internal:8080/v1/chat/completions
LLAMA_MODEL=qwen3.5-35b

# How often (seconds) the processor polls Miniflux for new articles
POLL_INTERVAL=300

# Max article content length (chars) sent to the LLM
MAX_CONTENT_LENGTH=64000

# Retries on malformed LLM output before writing to failed_articles
MAX_RETRIES=1

# --- Email (Gmail SMTP) ---
SMTP_USER=
SMTP_PASSWORD=
EMAIL_RECIPIENTS=user1@example.com,user2@example.com
