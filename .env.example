# ============================================================
# AI News Aggregator — Environment Variables
# Copy to .env and fill in values before running docker compose
# ============================================================

# --- Miniflux Postgres ---
MINIFLUX_DB_PASSWORD=changeme_miniflux_db

# --- Miniflux ---
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=changeme_admin

# --- Output Postgres ---
OUTPUT_DB_PASSWORD=changeme_output_db

# --- News Processor ---
# Generate this from Miniflux UI -> Settings -> API Keys after first boot
MINIFLUX_API_KEY=

# --- LLM Backend ---
# Supported backends: llama.cpp, litellm, ollama, vllm, generic
LLM_BACKEND=llama.cpp

# LLM API endpoint (adjust to your setup)
#   llama.cpp:  http://<host>:8080/v1/chat/completions
#   Ollama:     http://<host>:11434/v1/chat/completions
#   vLLM:       http://<host>:8000/v1/chat/completions
#   generic:    any OpenAI-compatible endpoint
LLM_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_MODEL=qwen3.5-35b

# API key (required for vLLM with auth, optional otherwise)
LLM_API_KEY=

# Whether to automatically append parameters to disable thinking/reasoning for DeepSeek-R1 / thinking models
# Supported backends: litellm, llama.cpp, vllm, ollama (default: true)
LLM_DISABLE_THINKING=true

# JSON string of extra backend-specific request payload parameters to merge recursively (optional)
# Example: LLM_EXTRA_PARAMS={"temperature": 0.2, "options": {"top_k": 40}}
LLM_EXTRA_PARAMS=

# How often (seconds) the processor polls Miniflux for new articles
POLL_INTERVAL=300

# Max article content length (chars) sent to the LLM
MAX_CONTENT_LENGTH=64000

# Retries on malformed LLM output before writing to failed_articles
MAX_RETRIES=1

# How many hours of processed news to keep in the database
PURGE_INTERVAL_HOURS=48

# Path to file containing custom system prompt (optional)
SYSTEM_PROMPT_FILE=

# Prompt version to store with processed articles for tracking
PROMPT_VERSION=1

# Healthcheck server port for processor and mcp-server
HEALTH_PORT=9090

# --- Email ---
# SMTP server settings (defaults to Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# Email rate limit (emails per minute) — prevents accidental spam
# Default: 10 (configurable via EMAIL_RATE_LIMIT env var)
# Set to 0 to disable (NOT recommended)
EMAIL_RATE_LIMIT=10
